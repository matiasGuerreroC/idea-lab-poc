# Configuración del Servidor
PORT=8000
HOST=127.0.0.1

# API Keys para la ejecución del proyecto
GEMINI_API_KEY=tu_api_key_de_ai_studio_aqui
GROQ_API_KEY=tu_api_key_de_groq_aqui

# Configuración del Triage Agent (Fase de conversación inicial)
TRIAGE_PROVIDER=gemini                # Opciones: gemini | groq
TRIAGE_MODEL=gemini-2.5-flash

# Configuración del Planner Agent (Creación de tareas - Gate 1)
PLANNER_PROVIDER=groq                 # Opciones: gemini | groq
PLANNER_MODEL=llama-3.3-70b-specdec   # O el modelo equivalente disponible en tu Groq

# Configuración del Executor Agent (Arquitectura y Mermaid - Gate 2)
EXECUTOR_PROVIDER=gemini              # Opciones: gemini | groq
EXECUTOR_MODEL=gemini-2.5-flash